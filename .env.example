# Токен бота от @BotFather
BOT_TOKEN=123456789:AAExampleTokenGoesHere

# ID группы/чата мастеров (обычно отрицательное число для групп)
MASTERS_CHAT_ID=-1001234567890

# Публичный URL, на который Telegram будет слать апдейты
# должен совпадать по пути с WEBHOOK_PATH
WEBHOOK_URL=https://your-app.onrender.com/webhook
WEBHOOK_PATH=/webhook

# Произвольная секретная строка — Telegram будет присылать её в заголовке
# X-Telegram-Bot-Api-Secret-Token, чтобы никто посторонний не мог слать
# фейковые апдейты на ваш webhook. Сгенерируйте что-то случайное.
WEBHOOK_SECRET=change-me-to-a-random-string

PORT=10000
DB_PATH=orders.db
